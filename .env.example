# =============================================================================
# RAG Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Nested config objects use double-underscore (__) as the delimiter,
# e.g.  CHARACTER_CHUNKER__CHUNK_SIZE=800
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Full async DSN for PostgreSQL.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
POSTGRES_DSN=postgresql+asyncpg://postgres:password@localhost:5432/graphmind

# Vector / full-text search plugin to use.
# Options: pgvector | pgsearch
POSTGRES_PLUGIN=pgvector


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Python log level for the application.
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# CHUNKING — GLOBAL STRATEGY
# -----------------------------------------------------------------------------

# Which chunking strategy to apply to all ingested documents.
# Options:
#   character_based_fixed_size  — splits on characters (default)
#   token_based_fixed_size      — splits on tokens using tiktoken
#   semantic                    — groups sentences by semantic similarity
CHUNKING_STRATEGY=character_based_fixed_size


# -----------------------------------------------------------------------------
# CHUNKING — CHARACTER-BASED (used when CHUNKING_STRATEGY=character_based_fixed_size)
# -----------------------------------------------------------------------------

# Maximum number of characters per chunk.
CHARACTER_CHUNKER__CHUNK_SIZE=500

# Overlap as a fraction of chunk size (0.0 – 1.0).
# e.g. 0.15 = 15 % overlap → 75 characters of overlap for a 500-char chunk.
CHARACTER_CHUNKER__CHUNK_OVERLAP_PCT=0.15


# -----------------------------------------------------------------------------
# CHUNKING — TOKEN-BASED (used when CHUNKING_STRATEGY=token_based_fixed_size)
# -----------------------------------------------------------------------------

# Maximum number of tokens per chunk.
TOKEN_CHUNKER__CHUNK_SIZE=500

# Overlap as a fraction of chunk size (0.0 – 1.0).
TOKEN_CHUNKER__CHUNK_OVERLAP_PCT=0.15

# tiktoken encoding to use for tokenisation.
# Options: cl100k_base (GPT-3.5 / GPT-4) | p50k_base (Codex) | r50k_base (GPT-2)
TOKEN_CHUNKER__ENCODING_NAME=cl100k_base


# -----------------------------------------------------------------------------
# CHUNKING — SEMANTIC (used when CHUNKING_STRATEGY=semantic)
# -----------------------------------------------------------------------------

# Method used to detect breakpoints between semantic groups.
# Options:
#   percentile        — split when similarity drops below the Nth percentile
#   standard_deviation — split when similarity drops > N standard deviations below mean
#   interquartile     — split using the interquartile range
SEMANTIC_CHUNKER__BREAKPOINT_THRESHOLD_TYPE=percentile

# Numeric threshold value that corresponds to the chosen threshold type.
# For percentile: 0 – 100  (default 95 = top 5 % of drops trigger a split)
# For standard_deviation / interquartile: floating-point multiplier
SEMANTIC_CHUNKER__BREAKPOINT_THRESHOLD_AMOUNT=95.0

# Number of neighbouring sentences to include when computing the embedding
# for each sentence (larger = more context, slower).
SEMANTIC_CHUNKER__BUFFER_SIZE=1


# -----------------------------------------------------------------------------
# EMBEDDING
# -----------------------------------------------------------------------------

# Embedding provider to use.
# Options: huggingface | openai
EMBEDDING_PROVIDER=huggingface

# Embedding model identifier.
# HuggingFace options : BAAI/bge-base-en-v1.5
# OpenAI options      : text-embedding-ada-002 | text-embedding-3-small | text-embedding-3-large
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Number of dimensions produced by the chosen embedding model.
# Must match the vector column size in your Postgres schema.
# BAAI/bge-base-en-v1.5     → 768
# text-embedding-ada-002     → 1536
# text-embedding-3-small     → 1536
# text-embedding-3-large     → 3072
EMBEDDING_DIMENSIONS=1536

# Required only when EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=
